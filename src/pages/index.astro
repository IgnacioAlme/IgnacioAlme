---
import Layout from '../layouts/Layout.astro';
import CityScene from '../components/CityScene.astro';
---

<Layout>
  <div class="landing-page">
    <CityScene />

    <style is:global>
      :root {
        --gtBlue: #25aff4;
        --gtDark: #0a0c10;
        --gtPanel: rgba(10, 12, 16, 0.85);
      }

      body {
        background-color: var(--gtDark);
        color: #ffffff;
        overflow: hidden;
        height: 100vh;
        width: 100vw;
        font-family: 'Space Grotesk', sans-serif;
        margin: 0;
      }

      .gt-panel {
        border: 1px solid rgba(37, 175, 244, 0.3);
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.5), inset 0 0 10px rgba(37, 175, 244, 0.05);
        backdrop-filter: blur(8px);
        background-color: var(--gtPanel);
      }

      .node-hover:hover .node-icon {
        transform: scale(1.1) translateY(-5px);
        filter: drop-shadow(0 0 15px var(--gtBlue));
      }

      .node-icon {
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
      }

      @keyframes spin {
        from { transform: translate(-50%, -50%) rotate(0deg); }
        to { transform: translate(-50%, -50%) rotate(360deg); }
      }

      @keyframes spin-reverse {
        from { transform: translate(-50%, -50%) rotate(360deg); }
        to { transform: translate(-50%, -50%) rotate(0deg); }
      }

      .landing-page {
        position: relative;
        width: 100vw;
        height: 100vh;
      }

      header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        z-index: 50;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        pointer-events: none;
        box-sizing: border-box;
      }

      header > div {
        pointer-events: auto;
      }

      .header-left {
        display: flex;
        gap: 1rem;
      }

      .panel {
        padding: 0.5rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .label {
        font-size: 0.625rem;
        font-weight: 700;
        color: var(--gtBlue);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .value {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .currency {
        color: var(--gtBlue);
      }

      .user-panel {
        padding: 1rem;
        text-align: right;
      }

      .user-name {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        text-transform: uppercase;
      }

      .user-role {
        font-size: 0.75rem;
        color: var(--gtBlue);
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .tags {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        margin-top: 0.5rem;
      }

      .tag {
        font-size: 0.5625rem;
        border: 1px solid rgba(37, 175, 244, 0.3);
        padding: 0.125rem 0.25rem;
        color: rgba(37, 175, 244, 0.5);
      }

      footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 1.5rem 2rem;
        z-index: 50;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        box-sizing: border-box;
      }

      .mission-status {
        padding: 1rem;
        max-width: 24rem;
      }

      .status-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.25rem;
      }

      .status-dot {
        width: 0.5rem;
        height: 0.5rem;
        background-color: var(--gtBlue);
        animation: pulse 2s ease-in-out infinite;
      }

      .status-label {
        font-size: 0.625rem;
        font-weight: 700;
        color: var(--gtBlue);
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .mission-text {
        font-size: 0.75rem;
        line-height: 1.5;
        opacity: 0.8;
      }

      .buttons {
        display: flex;
        gap: 0.5rem;
      }

      .btn {
        padding: 0.5rem 1.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: -0.01em;
        font-size: 0.875rem;
        cursor: pointer;
        border: none;
      }

      .btn-primary {
        background-color: var(--gtBlue);
        color: var(--gtDark);
      }

      .btn-primary:hover {
        background-color: white;
      }

      .btn-secondary {
        background-color: var(--gtPanel);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .btn-secondary:hover {
        border-color: var(--gtBlue);
      }

      .node-hover:hover .node-details {
        opacity: 1;
        transform: translateY(0);
      }

      .node-details {
        position: absolute;
        opacity: 0;
        transform: translateY(-10px);
        transition: all 0.3s ease;
        pointer-events: none;
        width: 20rem;
        margin-top: 0.5rem;
      }

      .node-details-content {
        background: rgba(10, 12, 16, 0.95);
        border: 1px solid rgba(37, 175, 244, 0.4);
        padding: 1rem;
        border-radius: 8px;
        backdrop-filter: blur(8px);
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.7);
      }

      .node-details-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--gtBlue);
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .node-details-text {
        font-size: 0.8125rem;
        line-height: 1.6;
        opacity: 0.9;
      }

      .node-details-list {
        list-style: none;
        padding: 0;
        margin: 0.75rem 0 0 0;
      }

      .node-details-list-item {
        font-size: 0.75rem;
        padding: 0.25rem 0;
        opacity: 0.85;
      }

      .node-details-list-item::before {
        content: '• ';
        color: var(--gtBlue);
        margin-right: 0.375rem;
      }

      .svg-pulse {
        animation: pulse 2s ease-in-out infinite;
      }

      .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
      }

      .modal-overlay.active {
        opacity: 1;
        visibility: visible;
      }

      .modal-content {
        background: rgba(10, 12, 16, 0.98);
        border: 1px solid rgba(37, 175, 244, 0.5);
        border-radius: 12px;
        padding: 2rem;
        max-width: 500px;
        max-height: 80vh;
        overflow-y: auto;
        position: relative;
        transform: scale(0.9);
        transition: transform 0.3s ease;
        box-shadow: 0 0 40px rgba(37, 175, 244, 0.2);
      }

      .modal-overlay.active .modal-content {
        transform: scale(1);
      }

      .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: var(--gtBlue);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.25rem;
        line-height: 1;
        transition: all 0.2s ease;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
      }

      .modal-close:hover {
        color: white;
        background: rgba(37, 175, 244, 0.2);
      }

      .modal-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--gtBlue);
      }

      .modal-intro {
        font-size: 0.9375rem;
        line-height: 1.8;
        opacity: 0.95;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: rgba(37, 175, 244, 0.08);
        border-left: 3px solid var(--gtBlue);
        border-radius: 0 8px 8px 0;
      }

      .modal-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        padding: 0.75rem;
        background: rgba(10, 12, 16, 0.5);
        border-radius: 8px;
      }

      .modal-contact-item {
        font-size: 0.8125rem;
        color: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        gap: 0.375rem;
      }

      .modal-contact-item::before {
        content: '';
        width: 6px;
        height: 6px;
        background: var(--gtBlue);
        border-radius: 50%;
      }

      .modal-section {
        margin-bottom: 1.5rem;
      }

      .modal-section:last-child {
        margin-bottom: 0;
      }

      .modal-section-title {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--gtBlue);
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .modal-section-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--gtBlue), transparent);
        opacity: 0.3;
      }

      .modal-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.5rem;
      }

      .modal-list-item {
        font-size: 0.8125rem;
        padding: 0.5rem 0.75rem;
        background: rgba(37, 175, 244, 0.06);
        border-radius: 4px;
        border-left: 2px solid rgba(37, 175, 244, 0.3);
        transition: all 0.2s ease;
      }

      .modal-list-item:hover {
        background: rgba(37, 175, 244, 0.12);
        border-left-color: var(--gtBlue);
      }

      .modal-job {
        padding: 1rem;
        background: rgba(37, 175, 244, 0.04);
        border-radius: 8px;
        margin-bottom: 1rem;
        border: 1px solid rgba(37, 175, 244, 0.15);
        transition: all 0.2s ease;
      }

      .modal-job:hover {
        background: rgba(37, 175, 244, 0.08);
        border-color: rgba(37, 175, 244, 0.3);
      }

      .modal-job:last-child {
        margin-bottom: 0;
      }

      .modal-job-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
        gap: 0.25rem;
      }

      .modal-job-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: white;
      }

      .modal-job-date {
        font-size: 0.75rem;
        color: var(--gtBlue);
        background: rgba(37, 175, 244, 0.15);
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-weight: 500;
      }

      .modal-job-list {
        list-style: none;
        padding: 0;
        margin: 0.5rem 0 0 0;
      }

      .modal-job-list-item {
        font-size: 0.8125rem;
        padding: 0.375rem 0;
        opacity: 0.85;
        position: relative;
        padding-left: 1rem;
      }

      .modal-job-list-item::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--gtBlue);
        opacity: 0.6;
      }

      .modal-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
      }

      .modal-tag {
        font-size: 0.6875rem;
        padding: 0.25rem 0.5rem;
        background: rgba(37, 175, 244, 0.15);
        color: var(--gtBlue);
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .nav-node {
        cursor: pointer;
      }
    </style>

    <header>
      <div class="header-left">
        <div class="gt-panel panel">
          <span class="label">Credits</span>
          <span class="value">10,000 <span class="currency">Cr</span></span>
        </div>
        <div class="gt-panel panel">
          <span class="label">Date</span>
          <span class="value uppercase" id="current-date">-- APR</span>
        </div>
      </div>
      <div class="gt-panel user-panel">
        <h1 class="user-name">Ignacio Almenar</h1>
        <p class="user-role">Associate degree in Computer Science</p>
        <div class="tags">
          <span class="tag">RESI: ARG</span>
          <span class="tag">LVL: 24</span>
        </div>
      </div>
    </header>

    <div class="modal-overlay" id="modalOverlay">
      <div class="modal-content" id="modalContent">
        <button class="modal-close" id="modalClose">&times;</button>
        <div id="modalBody"></div>
      </div>
    </div>

    <footer>
      <div class="gt-panel mission-status">
        <div class="status-header">
          <div class="status-dot"></div>
          <span class="status-label">Mission Status</span>
        </div>
        <p class="mission-text">
          Full Stack Developer. Building scalable web apps with React, Node.js & AWS. Open to new opportunities.
        </p>
      </div>
      <div class="buttons">
        <button class="gt-panel btn btn-primary">Enter Menu</button>
        <button class="gt-panel btn btn-secondary">Options</button>
      </div>
    </footer>
  </div>
</Layout>

<script>
  // Type declaration for openModal added by CityScene component
  declare global {
    interface Window {
      openModal: (id: string) => void;
    }
  }

  const modalOverlay = document.getElementById('modalOverlay');
  const modalClose = document.getElementById('modalClose');

  // Sentinel button click handlers for modals
  document.querySelectorAll('[data-modal]').forEach(btn => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal');
      if (modalId && typeof window.openModal === 'function') {
        window.openModal(modalId);
      }
    });
  });

  if (modalClose) {
    modalClose.addEventListener('click', () => {
      if (modalOverlay) {
        modalOverlay.classList.remove('active');
      }
    });
  }

  if (modalOverlay) {
    modalOverlay.addEventListener('click', (e) => {
      if (e.target === modalOverlay) {
        modalOverlay.classList.remove('active');
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modalOverlay?.classList.contains('active')) {
      modalOverlay.classList.remove('active');
    }
  });

  function updateHUD() {
    const now = new Date();
    const day = now.getDate();
    const monthNames = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"];
    const month = monthNames[now.getMonth()];
    const dateElement = document.getElementById('current-date');
    if (dateElement) {
      dateElement.textContent = `${day} ${month}`;
    }
  }
  updateHUD();
  setInterval(updateHUD, 60000);
</script>
