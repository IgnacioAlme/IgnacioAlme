---
// CardView.astro - Mobile card-based presentation
---

<div id="card-view" class="card-view">
  <div class="cards-container">
    <!-- Profile Card -->
    <article class="card" data-modal="profile">
      <div class="card-icon card-icon-profile">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
        </svg>
      </div>
      <h2 class="card-title">About Me</h2>
      <p class="card-subtitle">Full Stack Developer</p>
      <p class="card-description">
        Computer Science Technician at UTN. Passionate about building scalable web applications with React, Node.js & AWS.
      </p>
      <div class="card-tags">
        <span class="card-tag">English C1</span>
        <span class="card-tag">Argentina</span>
      </div>
    </article>

    <!-- Experience Card -->
    <article class="card" data-modal="experience">
      <div class="card-icon card-icon-experience">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="7" width="20" height="14" rx="2"/>
          <path d="M16 3v4M8 3v4"/>
        </svg>
      </div>
      <h2 class="card-title">Work Experience</h2>
      <div class="card-jobs">
        <div class="card-job">
          <span class="card-job-title">Subsecretary of Science & Tech</span>
          <span class="card-job-date">Sep 2024 - Present</span>
        </div>
        <div class="card-job">
          <span class="card-job-title">Shuhariko</span>
          <span class="card-job-date">Feb 2023 - May 2025</span>
        </div>
        <div class="card-job">
          <span class="card-job-title">BIOS Informática</span>
          <span class="card-job-date">Sep 2025 - Present</span>
        </div>
      </div>
    </article>

    <!-- Skills Card -->
    <article class="card" data-modal="skills">
      <div class="card-icon card-icon-skills">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <h2 class="card-title">Technical Skills</h2>
      <div class="card-skills-grid">
        <span class="skill-badge">React</span>
        <span class="skill-badge">TypeScript</span>
        <span class="skill-badge">Node.js</span>
        <span class="skill-badge">Express</span>
        <span class="skill-badge">AWS</span>
        <span class="skill-badge">Python</span>
        <span class="skill-badge">MariaDB</span>
        <span class="skill-badge">WebSockets</span>
      </div>
    </article>

    <!-- Showcase Card -->
    <article class="card" data-modal="showcase">
      <div class="card-icon card-icon-showcase">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="M21 15l-5-5L5 21"/>
        </svg>
      </div>
      <h2 class="card-title">Showcase</h2>
      <p class="card-description">
        Explore my projects and experiments. Real-time collaboration platforms, e-commerce solutions, and AI-powered applications.
      </p>
      <div class="card-cta">
        <span class="card-coming-soon">Coming Soon</span>
      </div>
    </article>

    <!-- Resume Card -->
    <article class="card" data-card-download="Ignacio Almenar CV dev - ENG-3.pdf">
      <div class="card-icon card-icon-resume">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
        </svg>
      </div>
      <h2 class="card-title">Resume</h2>
      <p class="card-description">
        Download my resume to see my full background, education, and detailed work history.
      </p>
      <button class="card-download-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <path d="M7 10l5 5 5-5"/>
          <path d="M12 15V3"/>
        </svg>
        Download CV
      </button>
    </article>
  </div>
</div>

<style>
  .card-view {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--gtDark, #0a0c10);
    z-index: 10;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 1rem;
    padding-bottom: 5rem;
    box-sizing: border-box;
  }

  .card-view.active {
    display: block;
  }

  .cards-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
    padding-top: 4rem;
  }

  .card {
    background: rgba(26, 38, 56, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(129, 236, 255, 0.15);
    border-radius: 12px;
    padding: 1.25rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .card:active {
    transform: scale(0.98);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .card-icon svg {
    width: 24px;
    height: 24px;
  }

  .card-icon-profile {
    background: rgba(37, 175, 244, 0.15);
    color: #25aff4;
  }

  .card-icon-experience {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }

  .card-icon-skills {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .card-icon-showcase {
    background: rgba(234, 179, 8, 0.15);
    color: #eab308;
  }

  .card-icon-resume {
    background: rgba(139, 92, 246, 0.15);
    color: #8b5cf6;
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.25rem 0;
  }

  .card-subtitle {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 0.75rem 0;
  }

  .card-description {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 0.75rem 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-tag {
    font-size: 0.6875rem;
    padding: 0.25rem 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-jobs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-job {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-job-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: white;
  }

  .card-job-date {
    font-size: 0.6875rem;
    color: #81ECFF;
    background: rgba(129, 236, 255, 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .card-skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-badge {
    font-size: 0.75rem;
    padding: 0.375rem 0.75rem;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 20px;
    color: #ef4444;
    font-weight: 600;
  }

  .card-cta {
    margin-top: 0.5rem;
  }

  .card-coming-soon {
    font-size: 0.75rem;
    font-weight: 700;
    color: #eab308;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: #8b5cf6;
    color: white;
    border: none;
    border-radius: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 0.5rem;
  }

  .card-download-btn:hover {
    background: #a78bfa;
    transform: translateY(-2px);
  }

  .card-download-btn:active {
    transform: translateY(0);
  }
</style>

<script>
  // Handle card clicks
  const cardView = document.getElementById('card-view');
  
  if (cardView) {
    // Card modal clicks
    cardView.querySelectorAll('[data-modal]').forEach(card => {
      card.addEventListener('click', () => {
        const modalId = card.getAttribute('data-modal');
        if (modalId && typeof window.openModal === 'function') {
          window.openModal(modalId);
        }
      });
    });

    // Download button clicks
    cardView.querySelectorAll('[data-card-download]').forEach(card => {
      card.addEventListener('click', (e) => {
        // Don't trigger if clicking the download button directly
        if ((e.target as HTMLElement).closest('.card-download-btn')) {
          return;
        }
        
        const filename = card.getAttribute('data-card-download');
        if (filename) {
          const link = document.createElement('a');
          link.href = `${import.meta.env.BASE_URL}docs/${filename}`;
          link.download = filename;
          link.click();
        }
      });
    });

    // Handle download button clicks directly
    cardView.querySelectorAll('.card-download-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const card = (e.currentTarget as HTMLElement).closest('[data-card-download]');
        if (card) {
          const filename = card.getAttribute('data-card-download');
          if (filename) {
            const link = document.createElement('a');
            link.href = `${import.meta.env.BASE_URL}docs/${filename}`;
            link.download = filename;
            link.click();
          }
        }
      });
    });
  }
</script>
