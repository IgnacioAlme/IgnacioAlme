<canvas id="city-canvas"></canvas>

<script>
import * as THREE from 'three';
import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';

// ============================================
// CONFIG
// ============================================
const CONFIG = {
  // Camera (polar coordinates)
  CAMERA_RADIUS: 12,
  CAMERA_HEIGHT: 16,
  
  // Lighting
  SUN_COLOR: 0xfff8e0,
  SUN_INTENSITY: 1.8,
  AMBIENT_INTENSITY: 0.25,
  
  // Atmosphere
  FOG_DENSITY: 0.015,
  
  // Bloom
  BLOOM_THRESHOLD: 0.2,
  BLOOM_STRENGTH: 0.8,
  BLOOM_RADIUS: 0.5,
  
  // Colors
  GT_BLUE: 0x25aff4,
  GT_DARK: 0x0a0c10,
  
  // Buildings
  DECORATION_COUNT: 40,
  MAP_SIZE: 40,
  CENTER_CLEAR_RADIUS: 12
};

// GT Palette for decoration buildings
const GT_PALETTE = [
  0x25aff4, // GT Blue
  0x22c55e, // Green
  0xef4444, // Red
  0xeab308, // Yellow
  0x8b5cf6, // Purple
  0xf97316, // Orange
  0x06b6d4, // Cyan
  0xec4899  // Pink
];

// Colors: hex values
const BUILDING_CONFIG = [
  { id: 'profile', type: 'profile', x: 0, z: -8, label: 'Profile Hub', color: 0x25aff4 },
  { id: 'experience', type: 'experience', x: 7.6, z: -2.5, label: 'Experience', color: 0x22c55e },
  { id: 'skills', type: 'skills', x: 4.7, z: 6.5, label: 'Technical Skills', color: 0xef4444 },
  { id: 'showcase', type: 'showcase', x: -4.7, z: 6.5, label: 'Showcase', color: 0xeab308 },
  { id: 'resume', type: 'resume', x: -7.6, z: -2.5, label: 'Resume', color: 0x8b5cf6, download: 'Ignacio Almenar CV dev - ENG-3.pdf' }
];

const DECORATION_COUNT = CONFIG.DECORATION_COUNT;
const MAP_SIZE = CONFIG.MAP_SIZE;
const CENTER_CLEAR_RADIUS = CONFIG.CENTER_CLEAR_RADIUS;
// ============================================

const canvas = document.getElementById('city-canvas');
if (!canvas) {
  console.error('Canvas not found');
  throw new Error('Canvas not found');
}

canvas.style.position = 'fixed';
canvas.style.top = '0';
canvas.style.left = '0';
canvas.style.width = '100%';
canvas.style.height = '100%';
canvas.style.zIndex = '0';
canvas.style.pointerEvents = 'auto';

const scene = new THREE.Scene();
scene.background = new THREE.Color(CONFIG.GT_DARK);

// Separate scene for labels (no bloom)
const labelsScene = new THREE.Scene();

// Add atmospheric fog
scene.fog = new THREE.FogExp2(CONFIG.GT_DARK, CONFIG.FOG_DENSITY);

// Polar coordinate camera system
let cameraAngle = 0.3;
const CAMERA_RADIUS = CONFIG.CAMERA_RADIUS;
const CAMERA_HEIGHT = CONFIG.CAMERA_HEIGHT;

const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);

function updateCameraPosition() {
  camera.position.x = Math.sin(cameraAngle) * CAMERA_RADIUS;
  camera.position.z = Math.cos(cameraAngle) * CAMERA_RADIUS;
  camera.position.y = CAMERA_HEIGHT;
  camera.lookAt(0, 0, 0);
}

// Initialize camera position
updateCameraPosition();

const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

const clickableObjects: THREE.Object3D[] = [];

// ============================================
// POST-PROCESSING (Bloom)
// ============================================
const composer = new EffectComposer(renderer);
const renderPass = new RenderPass(scene, camera);
composer.addPass(renderPass);

const bloomPass = new UnrealBloomPass(
  new THREE.Vector2(window.innerWidth, window.innerHeight),
  CONFIG.BLOOM_STRENGTH,
  CONFIG.BLOOM_RADIUS,
  CONFIG.BLOOM_THRESHOLD
);
composer.addPass(bloomPass);

// ============================================
// LIGHTING
// ============================================
// Soft ambient light with low intensity
const ambientLight = new THREE.AmbientLight(0xffffff, CONFIG.AMBIENT_INTENSITY);
scene.add(ambientLight);

// Strong sun directional light - warm color, dramatic low angle
const sunLight = new THREE.DirectionalLight(CONFIG.SUN_COLOR, CONFIG.SUN_INTENSITY);
sunLight.position.set(40, 60, 20);
sunLight.castShadow = false;
scene.add(sunLight);

// Rim light for neon edge glow effect
const rimLight = new THREE.DirectionalLight(CONFIG.GT_BLUE, 0.8);
rimLight.position.set(-20, 10, -15);
scene.add(rimLight);

// Subtle fill light from opposite side
const fillLight = new THREE.DirectionalLight(0x4a5568, 0.3);
fillLight.position.set(-30, 20, 30);
scene.add(fillLight);

// ============================================
// GROUND
// ============================================
const groundGeometry = new THREE.PlaneGeometry(100, 100);
const groundMaterial = new THREE.MeshStandardMaterial({ 
  color: 0x1a1f26, 
  roughness: 0.4, 
  metalness: 0.6 
});
const ground = new THREE.Mesh(groundGeometry, groundMaterial);
ground.rotation.x = -Math.PI / 2;
ground.position.y = -0.01;
scene.add(ground);

// ============================================
// GRID - Brighter GT-style
// ============================================
const gridHelper = new THREE.GridHelper(100, 20, CONFIG.GT_BLUE, 0x1a1f26);
if (gridHelper.material instanceof THREE.Material) {
  (gridHelper.material as THREE.LineBasicMaterial).opacity = 0.6;
  (gridHelper.material as THREE.LineBasicMaterial).transparent = true;
}
scene.add(gridHelper);

// ============================================
// ROAD LINES (Glowing paths)
// ============================================
function createRoadLines() {
  const roadMaterial = new THREE.MeshBasicMaterial({ 
    color: CONFIG.GT_BLUE, 
    transparent: true, 
    opacity: 0.8 
  });
  
  // Create main cross roads
  const roadH = new THREE.Mesh(
    new THREE.PlaneGeometry(60, 0.3),
    roadMaterial
  );
  roadH.rotation.x = -Math.PI / 2;
  roadH.position.y = 0.01;
  scene.add(roadH);
  
  const roadV = new THREE.Mesh(
    new THREE.PlaneGeometry(0.3, 60),
    roadMaterial
  );
  roadV.rotation.x = -Math.PI / 2;
  roadV.position.y = 0.01;
  scene.add(roadV);
  
  // Create diagonal accent lines
  const diagMaterial = new THREE.MeshBasicMaterial({ 
    color: 0x22c55e, 
    transparent: true, 
    opacity: 0.5 
  });
  
  for (let i = -2; i <= 2; i++) {
    if (i === 0) continue;
    const diagRoad = new THREE.Mesh(
      new THREE.PlaneGeometry(0.15, 50),
      diagMaterial
    );
    diagRoad.rotation.x = -Math.PI / 2;
    diagRoad.rotation.z = Math.PI / 4;
    diagRoad.position.y = 0.01;
    diagRoad.position.x = i * 8;
    scene.add(diagRoad);
  }
}

createRoadLines();

// ============================================
// BUILDING CREATION
// ============================================
function createBuildingGroup(x: number, z: number, type: string, modalId: string, color: number, download?: string) {
  const group = new THREE.Group();
  group.position.set(x, 0, z);
  group.userData = { modal: modalId };
  if (download) group.userData.download = download;

  const materialAccent = new THREE.MeshStandardMaterial({ 
    color: color, 
    roughness: 0.3, 
    metalness: 0.5, 
    emissive: color, 
    emissiveIntensity: 0.4 
  });

  if (type === 'profile') {
    // Cylinder body
    const cylinder = new THREE.Mesh(new THREE.CylinderGeometry(0.5, 0.5, 5, 16), materialAccent);
    cylinder.position.y = 2.5;
    cylinder.userData.modal = modalId;
    group.add(cylinder);
    // Torus halo
    const torus = new THREE.Mesh(new THREE.TorusGeometry(1, 0.15, 16, 100), materialAccent);
    torus.position.y = 5.3;
    torus.userData.modal = modalId;
    group.add(torus);
    clickableObjects.push(cylinder, torus);
  } else if (type === 'experience') {
    // Main box body
    const box = new THREE.Mesh(new THREE.BoxGeometry(2, 4, 2), materialAccent);
    box.position.y = 2;
    box.userData.modal = modalId;
    group.add(box);
    // Cylinder mast
    const mast = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 3, 8), materialAccent);
    mast.position.set(0, 5.5, 0);
    mast.userData.modal = modalId;
    group.add(mast);
    clickableObjects.push(box, mast);
  } else if (type === 'skills') {
    // Cone body
    const cone = new THREE.Mesh(new THREE.ConeGeometry(0.75, 4, 4), materialAccent);
    cone.position.y = 2;
    cone.userData.modal = modalId;
    group.add(cone);
    // Top accent
    const coneTop = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 0.5, 8), materialAccent);
    coneTop.position.y = 4.5;
    coneTop.userData.modal = modalId;
    group.add(coneTop);
    clickableObjects.push(cone, coneTop);
  } else if (type === 'showcase') {
    // Main body
    const body = new THREE.Mesh(new THREE.BoxGeometry(2, 3, 2), materialAccent);
    body.position.y = 1.5;
    body.userData.modal = modalId;
    group.add(body);
    // Arch accent
    const arch = new THREE.Mesh(new THREE.BoxGeometry(1.8, 1.2, 0.2), materialAccent);
    arch.position.set(0, 3.6, 0);
    arch.userData.modal = modalId;
    group.add(arch);
    clickableObjects.push(body, arch);
  } else if (type === 'resume') {
    // Sphere - unique rounded shape
    const sphere = new THREE.Mesh(new THREE.SphereGeometry(1, 32, 32), materialAccent);
    sphere.position.y = 2.5;
    sphere.userData.modal = modalId;
    if (download) sphere.userData.download = download;
    group.add(sphere);
    // Orbiting ring
    const ring = new THREE.Mesh(new THREE.TorusGeometry(1.5, 0.08, 16, 50), materialAccent);
    ring.position.y = 2.5;
    ring.rotation.x = Math.PI / 4;
    ring.userData.modal = modalId;
    if (download) ring.userData.download = download;
    group.add(ring);
    clickableObjects.push(sphere, ring);
  }

  scene.add(group);
}

// ============================================
// DECORATION BUILDINGS WITH EMISSIVE WINDOWS
// ============================================
function createDecorationBuilding(x: number, z: number) {
  const height = Math.random() * 4 + 2;
  const width = Math.random() * 1.5 + 0.8;
  const depth = Math.random() * 1.5 + 0.8;
  
  // Random accent color from GT palette
  const accentColor = GT_PALETTE[Math.floor(Math.random() * GT_PALETTE.length)];
  
  const group = new THREE.Group();
  group.position.set(x, 0, z);
  
  // Main building body
  const materialBase = new THREE.MeshStandardMaterial({ 
    color: CONFIG.GT_DARK, 
    roughness: 0.7, 
    metalness: 0.2 
  });
  const building = new THREE.Mesh(new THREE.BoxGeometry(width, height, depth), materialBase);
  building.position.y = height / 2;
  group.add(building);
  
  // Subtle accent band at base
  const materialAccent = new THREE.MeshStandardMaterial({ 
    color: accentColor, 
    roughness: 0.4, 
    metalness: 0.3, 
    emissive: accentColor, 
    emissiveIntensity: 0.15 
  });
  const baseBand = new THREE.Mesh(
    new THREE.BoxGeometry(width + 0.05, 0.2, depth + 0.05),
    materialAccent
  );
  baseBand.position.y = 0.1;
  group.add(baseBand);
  
  // Emissive window patterns on all 4 sides
  const windowRows = Math.floor(height / 1.2);
  const windowColsX = Math.floor(width / 0.6);
  const windowColsZ = Math.floor(depth / 0.6);

  const addWindowToFace = (faceX: number, faceZ: number, rotY: number, cols: number, isXFace: boolean) => {
    for (let row = 0; row < windowRows; row++) {
      for (let col = 0; col < cols; col++) {
        if (Math.random() > 0.4) {
          const windowMat = new THREE.MeshBasicMaterial({
            color: Math.random() > 0.5 ? 0xfff5e0 : 0x88ccff,
            transparent: true,
            opacity: 0.3 + Math.random() * 0.4
          });
          const windowMesh = new THREE.Mesh(
            new THREE.PlaneGeometry(0.2, 0.3),
            windowMat
          );
          windowMesh.rotation.y = rotY;
          const offsetX = isXFace ? 0 : (col - (cols - 1) / 2) * 0.5;
          const offsetZ = isXFace ? (col - (cols - 1) / 2) * 0.5 : 0;
          windowMesh.position.set(faceX + offsetX, row * 1.1 + 0.8, faceZ + offsetZ);
          group.add(windowMesh);
        }
      }
    }
  };

  addWindowToFace(0, depth / 2 + 0.01, 0, windowColsX, false);
  addWindowToFace(0, -depth / 2 - 0.01, Math.PI, windowColsX, false);
  addWindowToFace(width / 2 + 0.01, 0, Math.PI / 2, windowColsZ, true);
  addWindowToFace(-width / 2 - 0.01, 0, -Math.PI / 2, windowColsZ, true);
  
  scene.add(group);
}

// Create landmark buildings from config
BUILDING_CONFIG.forEach(b => {
  createBuildingGroup(b.x, b.z, b.type, b.id, b.color || CONFIG.GT_BLUE, b.download);
});

// Create decoration buildings
for (let i = 0; i < DECORATION_COUNT; i++) {
  const x = (Math.random() - 0.5) * MAP_SIZE;
  const z = (Math.random() - 0.5) * MAP_SIZE;
  if (Math.sqrt(x * x + z * z) > CENTER_CLEAR_RADIUS) {
    createDecorationBuilding(x, z);
  }
}

// ============================================
// LABELS (rendered in separate scene without bloom)
// ============================================
function createLabel(text: string, x: number, z: number, yOffset: number, modalId?: string, download?: string): THREE.Sprite {
  const labelCanvas = document.createElement('canvas');
  const ctx = labelCanvas.getContext('2d');
  labelCanvas.width = 512;
  labelCanvas.height = 128;
  if (ctx) {
    ctx.fillStyle = 'rgba(10, 12, 16, 0.8)';
    ctx.fillRect(0, 0, 512, 128);
    ctx.font = 'bold 48px Space Grotesk, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = '#ffffff';
    ctx.shadowColor = '#25aff4';
    ctx.shadowBlur = 15;
    ctx.fillText(text, 256, 64);
  }
  const sprite = new THREE.Sprite(new THREE.SpriteMaterial({ 
    map: new THREE.CanvasTexture(labelCanvas),
    transparent: true
  }));
  sprite.position.set(x, yOffset, z);
  sprite.scale.set(4, 1, 1);
  if (modalId) sprite.userData.modal = modalId;
  if (download) sprite.userData.download = download;
  labelsScene.add(sprite);

  const hitbox = new THREE.Mesh(
    new THREE.PlaneGeometry(4.5, 1.2),
    new THREE.MeshBasicMaterial({ visible: false })
  );
  hitbox.position.set(x, yOffset, z);
  hitbox.userData.modal = modalId;
  if (download) hitbox.userData.download = download;
  scene.add(hitbox);
  clickableObjects.push(hitbox);

  return sprite;
}

createLabel('Profile Hub', 0, -9, 5.5, 'profile');
createLabel('Experience', 8.5, -2.5, 5.5, 'experience');
createLabel('Technical Skills', 5, 7.5, 5.5, 'skills');
createLabel('Showcase', -5, 7.5, 5.5, 'showcase');
createLabel('Resume', -8.5, -2.5, 5.5, 'resume', 'Ignacio Almenar CV dev - ENG-3.pdf');

// ============================================
// SENTINEL POSITIONING
// ============================================
const sentinelContainer = document.createElement('div');
sentinelContainer.style.cssText = 'position:absolute;opacity:0;pointer-events:none;top:0;left:0;width:100%;height:100%';
document.body.appendChild(sentinelContainer);

const sentinelPositions = [
  { modal: 'profile', x: 0, z: -8 },
  { modal: 'experience', x: 7.6, z: -2.5 },
  { modal: 'skills', x: 4.7, z: 6.5 },
  { modal: 'showcase', x: -4.7, z: 6.5 },
  { modal: 'resume', x: -7.6, z: -2.5, download: 'Ignacio Almenar CV dev - ENG-3.pdf' }
];

sentinelPositions.forEach(pos => {
  const btn = document.createElement('button');
  btn.dataset.modal = pos.modal;
  btn.style.cssText = 'position:absolute;visibility:hidden;pointer-events:none';
  sentinelContainer.appendChild(btn);
});

const raycaster = new THREE.Raycaster();
const mouse = new THREE.Vector2();

function updateSentinelPositions() {
  sentinelPositions.forEach(pos => {
    const vector = new THREE.Vector3(pos.x, 2, pos.z);
    vector.project(camera);
    const x = (vector.x * 0.5 + 0.5) * window.innerWidth;
    const y = (-(vector.y * 0.5) + 0.5) * window.innerHeight;
    const btn = sentinelContainer.querySelector(`[data-modal="${pos.modal}"]`) as HTMLElement | null;
    if (btn) {
      btn.style.left = `${x}px`;
      btn.style.top = `${y}px`;
    }
  });
}

// ============================================
// EVENT HANDLERS
// ============================================
canvas.addEventListener('click', (event) => {
  mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
  mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
  raycaster.setFromCamera(mouse, camera);
  const intersects = raycaster.intersectObjects(clickableObjects);
  if (intersects.length > 0) {
    const target = intersects[0].object;
    const userData = target.userData as Record<string, unknown>;
    if (userData.download) {
      const link = document.createElement('a');
      link.href = `${import.meta.env.BASE_URL}docs/${userData.download}`;
      link.download = userData.download as string;
      link.click();
    } else if (userData.modal) {
      const modalId = userData.modal as string;
      const sentinel = sentinelContainer.querySelector(`[data-modal="${modalId}"]`) as HTMLButtonElement | null;
      if (sentinel) sentinel.click();
    }
  }
});

let isMouseDown = false;
let autoRotate = true;
let bloomEnabled = true;

canvas.addEventListener('mousedown', () => { isMouseDown = true; });
canvas.addEventListener('mouseup', () => { isMouseDown = false; });
canvas.addEventListener('mouseleave', () => { isMouseDown = false; });
canvas.addEventListener('mousemove', (e) => {
  if (isMouseDown) {
    // Only rotate - use movementX for delta
    cameraAngle -= e.movementX * 0.005;
    updateCameraPosition();
    updateSentinelPositions();
  }
});
// No zoom allowed - camera orbits at fixed radius

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
  composer.setSize(window.innerWidth, window.innerHeight);
});

