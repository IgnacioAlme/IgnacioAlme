---
import Layout from '../layouts/Layout.astro';
import CityScene from '../components/CityScene.astro';
---

<Layout>
  <div class="landing-page">
    <CityScene />

    <style is:global>
      :root {
        --gtBlue: #25aff4;
        --gtDark: #0a0c10;
        --gtPanel: rgba(10, 12, 16, 0.85);
      }

      body {
        background-color: var(--gtDark);
        color: #ffffff;
        overflow: hidden;
        height: 100vh;
        width: 100vw;
        font-family: 'Space Grotesk', sans-serif;
        margin: 0;
      }

      .gt-panel {
        border: 1px solid rgba(37, 175, 244, 0.3);
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.5), inset 0 0 10px rgba(37, 175, 244, 0.05);
        backdrop-filter: blur(8px);
        background-color: var(--gtPanel);
      }

      .node-hover:hover .node-icon {
        transform: scale(1.1) translateY(-5px);
        filter: drop-shadow(0 0 15px var(--gtBlue));
      }

      .node-icon {
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
      }

      @keyframes spin {
        from { transform: translate(-50%, -50%) rotate(0deg); }
        to { transform: translate(-50%, -50%) rotate(360deg); }
      }

      @keyframes spin-reverse {
        from { transform: translate(-50%, -50%) rotate(360deg); }
        to { transform: translate(-50%, -50%) rotate(0deg); }
      }

      .landing-page {
        position: relative;
        width: 100vw;
        height: 100vh;
      }

      header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        z-index: 50;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        pointer-events: none;
        box-sizing: border-box;
      }

      header > div {
        pointer-events: auto;
      }

      .header-left {
        display: flex;
        gap: 1rem;
      }

      .panel {
        padding: 0.5rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .label {
        font-size: 0.625rem;
        font-weight: 700;
        color: var(--gtBlue);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .value {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .currency {
        color: var(--gtBlue);
      }

      .user-panel {
        padding: 1rem;
        text-align: right;
      }

      .user-name {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        text-transform: uppercase;
      }

      .user-role {
        font-size: 0.75rem;
        color: var(--gtBlue);
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .tags {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        margin-top: 0.5rem;
      }

      .tag {
        font-size: 0.5625rem;
        border: 1px solid rgba(37, 175, 244, 0.3);
        padding: 0.125rem 0.25rem;
        color: rgba(37, 175, 244, 0.5);
      }

      footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 1.5rem 2rem;
        z-index: 50;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        box-sizing: border-box;
      }

      .mission-status {
        padding: 1rem;
        max-width: 24rem;
      }

      .status-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.25rem;
      }

      .status-dot {
        width: 0.5rem;
        height: 0.5rem;
        background-color: var(--gtBlue);
        animation: pulse 2s ease-in-out infinite;
      }

      .status-label {
        font-size: 0.625rem;
        font-weight: 700;
        color: var(--gtBlue);
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .mission-text {
        font-size: 0.75rem;
        line-height: 1.5;
        opacity: 0.8;
      }

      .buttons {
        display: flex;
        gap: 0.5rem;
      }

      .btn {
        padding: 0.5rem 1.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: -0.01em;
        font-size: 0.875rem;
        cursor: pointer;
        border: none;
      }

      .btn-primary {
        background-color: var(--gtBlue);
        color: var(--gtDark);
      }

      .btn-primary:hover {
        background-color: white;
      }

      .btn-secondary {
        background-color: var(--gtPanel);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .btn-secondary:hover {
        border-color: var(--gtBlue);
      }

      .node-hover:hover .node-details {
        opacity: 1;
        transform: translateY(0);
      }

      .node-details {
        position: absolute;
        opacity: 0;
        transform: translateY(-10px);
        transition: all 0.3s ease;
        pointer-events: none;
        width: 20rem;
        margin-top: 0.5rem;
      }

      .node-details-content {
        background: rgba(10, 12, 16, 0.95);
        border: 1px solid rgba(37, 175, 244, 0.4);
        padding: 1rem;
        border-radius: 8px;
        backdrop-filter: blur(8px);
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.7);
      }

      .node-details-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--gtBlue);
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .node-details-text {
        font-size: 0.8125rem;
        line-height: 1.6;
        opacity: 0.9;
      }

      .node-details-list {
        list-style: none;
        padding: 0;
        margin: 0.75rem 0 0 0;
      }

      .node-details-list-item {
        font-size: 0.75rem;
        padding: 0.25rem 0;
        opacity: 0.85;
      }

      .node-details-list-item::before {
        content: '• ';
        color: var(--gtBlue);
        margin-right: 0.375rem;
      }

      .svg-pulse {
        animation: pulse 2s ease-in-out infinite;
      }

      .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(6, 14, 27, 0.85);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
      }

      .modal-overlay.active {
        opacity: 1;
        visibility: visible;
      }

      .modal-content {
        background: rgba(26, 38, 56, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(129, 236, 255, 0.15);
        padding: 0;
        max-width: 560px;
        max-height: 80vh;
        overflow: hidden;
        position: relative;
        transform: scale(0.95) translateY(10px);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 0 40px rgba(129, 236, 255, 0.08);
      }

      .modal-overlay.active .modal-content {
        transform: scale(1) translateY(0);
        box-shadow: 0 0 60px rgba(129, 236, 255, 0.12);
      }

      .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: #81ECFF;
        font-size: 1.25rem;
        cursor: pointer;
        padding: 0.5rem;
        line-height: 1;
        transition: all 0.2s ease;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
      }

      .modal-close:hover {
        color: white;
        background: rgba(129, 236, 255, 0.1);
      }

      .modal-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 700;
        color: #81ECFF;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        padding: 1.25rem 1.5rem;
        background: rgba(16, 26, 41, 0.8);
        border-bottom: 1px solid rgba(129, 236, 255, 0.1);
      }

      .modal-body {
        padding: 1.5rem;
        max-height: calc(80vh - 50px);
        overflow-y: auto;
      }

      .modal-body::-webkit-scrollbar,
      ::-webkit-scrollbar {
        width: 6px;
      }

      .modal-body::-webkit-scrollbar-track,
      ::-webkit-scrollbar-track {
        background: #060E1B;
      }

      .modal-body::-webkit-scrollbar-thumb,
      ::-webkit-scrollbar-thumb {
        background: rgba(129, 236, 255, 0.25);
        border: none;
      }

      .modal-body::-webkit-scrollbar-thumb:hover,
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(129, 236, 255, 0.5);
      }

      /* Firefox scrollbar */
      .modal-body,
      * {
        scrollbar-width: thin;
        scrollbar-color: rgba(129, 236, 255, 0.25) #060E1B;
      }

      .modal-intro {
        font-size: 0.9375rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 1.75rem;
        padding: 1.25rem;
        background: #0A1421;
        position: relative;
      }

      .modal-intro::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #81ECFF, #7C98FF);
      }

      .modal-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.75rem;
        padding: 1rem;
        background: #0A1421;
      }

      .modal-contact-item {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .modal-contact-item::before {
        content: '';
        width: 4px;
        height: 4px;
        background: #81ECFF;
        box-shadow: 0 0 6px #81ECFF;
      }

      .modal-section {
        margin-bottom: 1.75rem;
        padding: 1rem;
        background: #101A29;
      }

      .modal-section:last-child {
        margin-bottom: 0;
      }

      .modal-section-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 700;
        color: #7C98FF;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .modal-section-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, rgba(124, 152, 255, 0.3), transparent);
      }

      .modal-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .modal-list-item {
        font-size: 0.8125rem;
        padding: 0.75rem 1rem;
        background: #1A2638;
        margin-bottom: 0.5rem;
        border-left: 2px solid #81ECFF;
        transition: all 0.2s ease;
      }

      .modal-list-item:last-child {
        margin-bottom: 0;
      }

      .modal-list-item:hover {
        background: rgba(129, 236, 255, 0.08);
        padding-left: 1.25rem;
      }

      .modal-job {
        padding: 1.25rem;
        background: #0A1421;
        margin-bottom: 1rem;
        transition: all 0.2s ease;
      }

      .modal-job:last-child {
        margin-bottom: 0;
      }

      .modal-job:hover {
        background: rgba(129, 236, 255, 0.03);
      }

      .modal-job-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .modal-job-title {
        font-size: 0.9375rem;
        font-weight: 700;
        color: white;
      }

      .modal-job-date {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        color: #81ECFF;
        background: rgba(129, 236, 255, 0.1);
        padding: 0.25rem 0.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .modal-job-list {
        list-style: none;
        padding: 0;
        margin: 0.75rem 0 0 0;
      }

      .modal-job-list-item {
        font-size: 0.8125rem;
        padding: 0.5rem 0;
        color: rgba(255, 255, 255, 0.75);
        position: relative;
        padding-left: 1.25rem;
        border-bottom: 1px solid rgba(129, 236, 255, 0.05);
      }

      .modal-job-list-item:last-child {
        border-bottom: none;
      }

      .modal-job-list-item::before {
        content: '▸';
        position: absolute;
        left: 0;
        color: #7C98FF;
      }

      .modal-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.75rem;
      }

      .modal-tag {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.625rem;
        padding: 0.375rem 0.75rem;
        background: #1A2638;
        color: #81ECFF;
        border-left: 2px solid #7C98FF;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
      }

      .modal-toggle {
        margin-bottom: 1rem;
      }

      .modal-toggle:last-child {
        margin-bottom: 0;
      }

      .toggle-label {
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
        padding: 0.75rem 1rem;
        background: #1A2638;
        transition: all 0.2s ease;
      }

      .toggle-input {
        appearance: none;
        width: 48px;
        height: 24px;
        background: #060E1B;
        border: 2px solid rgba(129, 236, 255, 0.3);
        position: relative;
        cursor: pointer;
        transition: all 0.3s ease;
        flex-shrink: 0;
      }

      .toggle-input::before {
        content: '';
        position: absolute;
        width: 14px;
        height: 14px;
        background: rgba(129, 236, 255, 0.5);
        top: 2px;
        left: 2px;
        transition: all 0.3s ease;
      }

      .toggle-label.active .toggle-input {
        background: linear-gradient(90deg, #81ECFF, #00E3FD);
        border-color: #81ECFF;
        box-shadow: 0 0 12px rgba(129, 236, 255, 0.4);
      }

      .toggle-label.active .toggle-input::before {
        transform: translateX(24px);
        background: #060E1B;
      }

      .toggle-text {
        font-family: 'Space Grotesk', sans-serif;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .modal-link {
        display: block;
        font-size: 0.8125rem;
        padding: 0.75rem 1rem;
        background: #1A2638;
        margin-bottom: 0.5rem;
        border-left: 2px solid #7C98FF;
        color: #81ECFF;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .modal-link:last-child {
        margin-bottom: 0;
      }

      .modal-link:hover {
        background: rgba(129, 236, 255, 0.08);
        padding-left: 1.25rem;
      }

      .nav-node {
        cursor: pointer;
      }
    </style>

    <header>
      <div class="header-left">
        <div class="gt-panel panel">
          <span class="label">Credits</span>
          <span class="value">10,000 <span class="currency">Cr</span></span>
        </div>
        <div class="gt-panel panel">
          <span class="label">Date</span>
          <span class="value uppercase" id="current-date">-- APR</span>
        </div>
      </div>
      <div class="gt-panel user-panel">
        <h1 class="user-name">Ignacio Almenar</h1>
        <p class="user-role">Associate degree in Computer Science</p>
        <div class="tags">
          <span class="tag">RESI: ARG</span>
          <span class="tag">LVL: 24</span>
        </div>
      </div>
    </header>

    <div class="modal-overlay" id="modalOverlay">
      <div class="modal-content" id="modalContent">
        <button class="modal-close" id="modalClose">&times;</button>
        <div class="modal-title" id="modalTitle"></div>
        <div id="modalBody" class="modal-body"></div>
      </div>
    </div>

    <footer>
      <div class="gt-panel mission-status">
        <div class="status-header">
          <div class="status-dot"></div>
          <span class="status-label">Mission Status</span>
        </div>
        <p class="mission-text">
          Full Stack Developer. Building scalable web apps with React, Node.js & AWS. Open to new opportunities.
        </p>
      </div>
      <div class="buttons">
        <button class="gt-panel btn btn-primary" data-modal="links">My Links</button>
        <button class="gt-panel btn btn-secondary" data-modal="options">Options</button>
      </div>
    </footer>
  </div>
</Layout>

<script>
  // Type declaration for openModal added by CityScene component
  declare global {
    interface Window {
      openModal: (id: string) => void;
    }
  }

  const modalOverlay = document.getElementById('modalOverlay');
  const modalClose = document.getElementById('modalClose');

  // Sentinel button click handlers for modals
  document.querySelectorAll('[data-modal]').forEach(btn => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal');
      if (modalId && typeof window.openModal === 'function') {
        window.openModal(modalId);
      }
    });
  });

  if (modalClose) {
    modalClose.addEventListener('click', () => {
      if (modalOverlay) {
        modalOverlay.classList.remove('active');
      }
    });
  }

  if (modalOverlay) {
    modalOverlay.addEventListener('click', (e) => {
      if (e.target === modalOverlay) {
        modalOverlay.classList.remove('active');
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modalOverlay?.classList.contains('active')) {
      modalOverlay.classList.remove('active');
    }
  });

  function updateHUD() {
    const now = new Date();
    const day = now.getDate();
    const monthNames = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"];
    const month = monthNames[now.getMonth()];
    const dateElement = document.getElementById('current-date');
    if (dateElement) {
      dateElement.textContent = `${day} ${month}`;
    }
  }
  updateHUD();
  setInterval(updateHUD, 60000);
</script>
