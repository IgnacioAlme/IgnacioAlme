      content: '<div class="modal-section"><div class="modal-section-title">Settings</div><div class="modal-toggle"><label class="toggle-label active"><input type="checkbox" id="toggleAutoRotate" checked onchange="window.toggleAutoRotate !== undefined && (document.getElementById(\'toggleAutoRotate\').closest(\'.toggle-label\').classList.toggle(\'active\', window.toggleAutoRotate()));\" class="toggle-input"><span class="toggle-text">Automatic Camera Rotation</span></label></div><div class="modal-toggle"><label class="toggle-label active"><input type="checkbox" id="toggleBloom" checked onchange="window.toggleBloom !== undefined && (document.getElementById(\'toggleBloom\').closest(\'.toggle-label\').classList.toggle(\'active\', window.toggleBloom()));\" class="toggle-input"><span class="toggle-text">Bloom Effect</span></label></div></div>'
    }
  };
  const data = modalData[id as keyof typeof modalData];
  if (data) {
    const modalTitle = document.getElementById('modalTitle');
    const modalBody = document.getElementById('modalBody');
    const modalOverlay = document.getElementById('modalOverlay');
    if (modalTitle) modalTitle.textContent = data.title;
    if (modalBody) modalBody.innerHTML = data.content;
    if (modalOverlay) modalOverlay.classList.add('active');
  }
});

updateSentinelPositions();

// ============================================
// ANIMATION LOOP
// ============================================
function animate() {
  requestAnimationFrame(animate);
  
  if (autoRotate && !isMouseDown) {
    cameraAngle += 0.0003;
    updateCameraPosition();
    updateSentinelPositions();
  }
  
  bloomPass.strength = bloomEnabled ? CONFIG.BLOOM_STRENGTH : 0;
  renderer.autoClear = false;
  composer.render();
  renderer.clearDepth();
  renderer.render(labelsScene, camera);
}

animate();

// ============================================
// TOGGLE FUNCTIONS (exposed to window)
// ============================================
(window as unknown as Record<string, unknown>).toggleAutoRotate = () => {
  autoRotate = !autoRotate;
  const checkbox = document.getElementById('toggleAutoRotate') as HTMLInputElement | null;
  if (checkbox) checkbox.checked = autoRotate;
  return autoRotate;
};

(window as unknown as Record<string, unknown>).toggleBloom = () => {
  bloomEnabled = !bloomEnabled;
  const checkbox = document.getElementById('toggleBloom') as HTMLInputElement | null;
  if (checkbox) checkbox.checked = bloomEnabled;
  return bloomEnabled;
};

console.log('CityScene initialized successfully');
</script>

